package example:example;

/// wit for the examples in this repo
world example {
    include wasi:webgpu/imports@0.0.1;
    include wasi-gfx:surface/webgpu-imports@0.1.0;
    include wasi-gfx:frame-buffer/imports@0.1.0;
    include wasi-gfx:surface/frame-buffer-imports@0.1.0;

    /// main entrypoint
    export start: async func();

    /// print to stdout
    import print: func(s: string);
}
